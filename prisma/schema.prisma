generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String         @id @default(uuid())
  email       String         @unique
  name        String
  password    String         @default("")
  image       String?
  title       String         @default("")
  description String         @default("")
  github      String         @default("")
  twitter     String         @default("")
  linkedin    String         @default("")
  portfolio   String         @default("")
  isPrivate   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  memberships TeamMember[]
  presences   FilePresence[]
  notifications Notification[]
  apiKeys     ApiKey[]
  ownedTeams  Team[]         @relation("TeamOwner")
  teamMembers TeamMember[]   @relation("TeamMembers")
  filePresences FilePresence[] @relation("FilePresences")
  invitationsSent Invitation[] @relation("InvitationsSent")
  invitationsReceived Invitation[] @relation("InvitationsReceived")
  notificationsById Notification[] @relation("Notifications")
  apiKeysById ApiKey[]       @relation("ApiKeys")
}

model Team {
  id           String              @id @default(uuid())
  teamName     String
  createdBy    String
  userId       String?
  description  String              @default("")
  industry     String              @default("")
  website      String              @default("")
  github       String              @default("")
  isPrivate    Boolean             @default(false)
  createdAt    DateTime            @default(now())
  files        File[]
  members      TeamMember[]
  invitations  Invitation[]
  libraryItems SharedLibraryItem[]
  orgSetting   OrgSetting?
  auditLogs    AuditLog[]
  owner        User?               @relation("TeamOwner", fields: [userId], references: [id], onDelete: SetNull)
}

model File {
  id             String         @id @default(uuid())
  fileName       String
  teamId         String
  createdBy      String
  archive        Boolean        @default(false)
  document       String         @default("")
  whiteboard     String         @default("")
  folder         String?
  createdAt      DateTime       @default(now())
  whiteboardText String         @default("")
  team           Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  versions       FileVersion[]
  presences      FilePresence[]
  sharedLinks    SharedLink[]
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userEmail String
  userId    String?
  role      String   @default("member")
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  userById  User?    @relation("TeamMembers", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([teamId, userEmail])
  @@unique([teamId, userId])
}

model FileVersion {
  id             String   @id @default(uuid())
  fileId         String
  document       String   @default("")
  whiteboard     String   @default("")
  version        Int
  createdByName  String   @default("Author")
  createdByImage String   @default("")
  note           String   @default("")
  createdAt      DateTime @default(now())
  file           File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

model FilePresence {
  id              String   @id @default(uuid())
  fileId          String
  userEmail       String
  userId          String?
  userName        String
  userImage       String   @default("")
  userColor       String   @default("#6366f1")
  workspaceStatus String   @default("Viewing workspace")
  lastSeenAt      DateTime @updatedAt
  file            File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  userById        User?    @relation("FilePresences", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([fileId, userEmail])
  @@unique([fileId, userId])
}

model Invitation {
  id           String   @id @default(uuid())
  teamId       String
  teamName     String
  inviterEmail String
  inviteeEmail String
  inviterId    String?
  inviteeId    String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter      User?    @relation("InvitationInviter", fields: [inviterEmail], references: [email], onDelete: SetNull)
  invitee      User?    @relation("InvitationInvitee", fields: [inviteeEmail], references: [email], onDelete: SetNull)
  inviterById  User?    @relation("InvitationsSent", fields: [inviterId], references: [id], onDelete: SetNull)
  inviteeById  User?    @relation("InvitationsReceived", fields: [inviteeId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String   @id @default(uuid())
  userEmail String
  userId    String?
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  userById  User?    @relation("Notifications", fields: [userId], references: [id], onDelete: SetNull)
}

model SharedLibraryItem {
  id          String   @id @default(uuid())
  teamId      String
  name        String
  description String   @default("")
  sourceUrl   String   @default("")
  author      String   @default("")
  payload     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, updatedAt])
}

model ApiKey {
  id        String    @id @default(uuid())
  userEmail String
  userId    String?
  name      String
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  hashedKey String    @unique
  maskedKey String    @default("")
  scope     String    @default("read-write")
  user      User      @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  userById  User?     @relation("ApiKeys", fields: [userId], references: [id], onDelete: SetNull)
}

model SharedLink {
  id           String    @id @default(uuid())
  fileId       String
  role         String    @default("viewer")
  passwordHash String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isActive     Boolean   @default(true)
  file         File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
}

model OrgSetting {
  id             String   @id @default(uuid())
  teamId         String   @unique
  allowedDomains String   @default("")
  ssoEnabled     Boolean  @default(false)
  ssoProvider    String   @default("saml")
  ssoMetadataUrl String   @default("")
  seatLimit      Int      @default(50)
  updatedAt      DateTime @updatedAt
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  teamId    String
  userEmail String
  ipAddress String   @default("")
  action    String
  context   String   @default("")
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
}

model SnykSettings {
  id     String @id @default(uuid())
  userId String @unique
  orgId  String
  token  String
}

model SonarcloudSettings {
  id           String   @id @default(uuid())
  userId       String   @unique
  organization String   @default("")
  projectKey   String   @default("")
  token        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UploadedFile {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  payload   String   @default("")
  createdAt DateTime @default(now())
}
