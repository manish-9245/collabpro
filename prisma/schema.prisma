datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String
  password    String   @default("")
  image       String?
  title       String   @default("")
  description String   @default("")
  github      String   @default("")
  twitter     String   @default("")
  linkedin    String   @default("")
  portfolio   String   @default("")
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Team {
  id          String   @id @default(uuid())
  teamName    String
  createdBy   String
  description String   @default("")
  industry    String   @default("")
  website     String   @default("")
  github      String   @default("")
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model File {
  id             String   @id @default(uuid())
  fileName       String
  teamId         String
  createdBy      String
  archive        Boolean  @default(false)
  document       String   @default("")
  whiteboard     String   @default("")
  whiteboardText String   @default("")
  folder         String?
  createdAt      DateTime @default(now())
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userEmail String
  role      String   @default("member") // "owner" or "member"
  createdAt DateTime @default(now())
}

model FileVersion {
  id             String   @id @default(uuid())
  fileId         String
  document       String   @default("")
  whiteboard     String   @default("")
  version        Int
  createdByName  String   @default("Author")
  createdByImage String   @default("")
  note           String   @default("")
  createdAt      DateTime @default(now())
}

model FilePresence {
  id              String   @id @default(uuid())
  fileId          String
  userEmail       String
  userName        String
  userImage       String   @default("")
  userColor       String   @default("#6366f1")
  workspaceStatus String   @default("Viewing workspace")
  lastSeenAt      DateTime @updatedAt

  @@unique([fileId, userEmail])
}

model Invitation {
  id           String   @id @default(uuid())
  teamId       String
  teamName     String
  inviterEmail String
  inviteeEmail String
  status       String   @default("pending") // "pending", "accepted", "declined"
  createdAt    DateTime @default(now())
}

model Notification {
  id         String   @id @default(uuid())
  userEmail  String   // Who gets the notification
  title      String
  message    String
  type       String   @default("info") // "invite", "response", "system"
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model SharedLibraryItem {
  id          String   @id @default(uuid())
  teamId      String
  name        String
  description String   @default("")
  sourceUrl   String   @default("")
  author      String   @default("")
  payload     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId, updatedAt])
}

model ApiKey {
  id          String    @id @default(uuid())
  userEmail   String
  name        String
  key         String    @unique
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model SharedLink {
  id           String    @id @default(uuid())
  fileId       String
  role         String    @default("viewer") // "viewer", "commenter", "editor"
  passwordHash String?   // optional password protection
  expiresAt    DateTime? // optional expiration date
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([fileId])
}
